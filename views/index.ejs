<!doctype html>
<html>
  <head>
    <title>Revision AI</title>
    <link href="/css/output.css" rel="stylesheet">
  </head>

  <body class="bg-gray-900 text-white">

    <!-- NAVBAR -->
    <nav class="bg-indigo-500/60 backdrop-blur-md border-b border-white/10">
      <div class="max-w-7xl mx-auto px-4">
        <div class="flex h-16 items-center justify-between">

          <!-- Logo -->
          <div class="flex items-center">
            <img
              class="h-8 w-auto"
              src="https://tailwindcss.com/plus-assets/img/logos/mark.svg?color=indigo&shade=500"
              alt="Logo"
            />
          </div>

          <!-- Right Side -->
          <div class="flex items-center gap-4">

            <!-- Notifications -->
            <button id="notifications-button"
              class="rounded-full p-1 text-gray-300 hover:text-white focus:outline-none">
              <img src="upload.png" class="h-6 w-6">
            </button>

            <div id="notifications-menu"
              class="hidden absolute right-20 top-16 w-48 rounded-md bg-gray-800 py-1 shadow-lg">
              <a class="block px-4 py-2 text-sm text-gray-300 hover:bg-white/5">No Updates</a>
            </div>

            <!-- Profile -->
            <div class="relative">
              <button id="profile-button"
                class="flex rounded-full focus:outline-none focus:ring-2 focus:ring-indigo-500">
                <img class="h-8 w-8 rounded-full"
                  src="https://images.unsplash.com/photo-1472099645785-5658abf4ff4e">
              </button>

              <div id="profile-menu"
                class="hidden absolute right-0 mt-2 w-48 rounded-md bg-gray-800 py-1 shadow-lg">
                <a class="block px-4 py-2 text-sm text-gray-300 hover:bg-white/5">Your profile</a>
                <a class="block px-4 py-2 text-sm text-gray-300 hover:bg-white/5">Settings</a>
                <a class="block px-4 py-2 text-sm text-gray-300 hover:bg-white/5">Sign out</a>
              </div>
            </div>

          </div>
        </div>
      </div>
    </nav>

    <!-- HERO SECTION -->
    <main class="flex flex-col items-center justify-center text-center px-4 min-h-[80vh]">

      <!-- Badge -->
      <div class="inline-flex items-center px-4 py-2 rounded-full bg-indigo-500/20 text-indigo-300 text-sm mb-6">
        AI-Powered Learning
      </div>

      <!-- Heading -->
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold mb-6 tracking-tight">
        Transform Documents into
        <span class="text-indigo-400 block mt-2">Study Flashcards</span>
      </h1>

      <!-- Description -->
      <p class="text-gray-400 max-w-2xl text-base md:text-lg mb-10">
        Upload any document and let AI create summaries and flashcards instantly.
        Study smarter, not harder.
      </p>

      <!-- Upload -->
      <form action="/upload-file" method="POST" enctype="multipart/form-data">
        <label
          class="flex flex-col items-center justify-center w-80 sm:w-96 h-44 bg-gray-800 border-2 border-dashed border-gray-600 rounded-lg hover:border-indigo-500 hover:bg-gray-700/50 transition cursor-pointer group">

          <!-- Icon -->
          <svg class="w-8 h-8 mb-4 text-gray-400 group-hover:text-indigo-400"
            fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M12 5v9m-5 0H5a1 1 0 0 0-1 1v4a1 1 0 0 0 1 1h14a1 1 0 0 0 1-1v-4a1 1 0 0 0-1-1h-2M8 9l4-5 4 5"/>
          </svg>

          <p class="text-sm text-gray-300 mb-2">Click to upload</p>

          <span class="text-xs text-gray-500">PDF • Max 10MB</span>

          <input id="file-upload" name="document" type="file"
            class="hidden" onchange="this.form.submit()" />
        </label>
      </form>

    </main>

    <!-- RESULT PREVIEW -->
    <div class="max-w-4xl mx-auto px-4 mb-16">
      <ul class="text-gray-300 text-sm space-y-2">
        <li><%= locals.fileName || '' %></li>
        <li><%= locals.fileMarkdown || '' %></li>
      </ul>
    </div>

    <!-- FOOTER -->
    <footer class="border-t border-white/10 py-6 text-center text-gray-500 text-sm">
      Powered by AI — Transform documents into flashcards instantly
    </footer>

    <!-- JAVASCRIPT -->
    <script>
      const notifyBtn = document.getElementById('notifications-button');
      const notifyMenu = document.getElementById('notifications-menu');

      const profileBtn = document.getElementById('profile-button');
      const profileMenu = document.getElementById('profile-menu');

      // Toggle notifications
      notifyBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        notifyMenu.classList.toggle('hidden');
      });

      // Toggle profile menu
      profileBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        profileMenu.classList.toggle('hidden');
      });

      // Close menus when clicking outside
      document.addEventListener('click', () => {
        notifyMenu.classList.add('hidden');
        profileMenu.classList.add('hidden');
      });

      // Escape key closes menus
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
          notifyMenu.classList.add('hidden');
          profileMenu.classList.add('hidden');
        }
      });
    </script>

  </body>
</html>